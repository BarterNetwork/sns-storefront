# ── Supabase ──────────────────────────────────────────────────────────────
# Get these from: Supabase dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here   # never expose to browser

# ── S&S Activewear API ────────────────────────────────────────────────────
# Get these from: ssactivewear.com/myaccount → API Key
SNS_ACCOUNT_NUMBER=your-account-number
SNS_API_KEY=your-api-key

# ── Sync secret ───────────────────────────────────────────────────────────
# A random string you generate — protects the /api/sync endpoint
# Generate one with:  openssl rand -hex 32
SYNC_SECRET=your-random-secret-here
